# Shared key required on /draft, /speak, /listen (blank = open).
ALLEN_API_KEY=

# ALLEN configuration. Copy to .env; never commit .env.

# --- LLM (the "company LLM" — TBD long-term) ---
ANTHROPIC_API_KEY=
# Override to the current preferred model id.
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Speech ---
# Reuse the RMG Creator OS ElevenLabs key (speech-out / "Express").
ELEVENLABS_API_KEY=
# ElevenLabs voice for ALLEN's own spoken responses (default: COM Coach Rahm).
ALLEN_VOICE_ID=Z3Gpg2pTWuj7g4RFQM9J
# Optional: OpenAI key for Whisper STT ("Listen"). Leave blank to disable /listen.
OPENAI_API_KEY=

# --- Google OAuth — unified Calendar + Gmail + Drive access across all accounts ---
# OAuth 2.0 client from Google Cloud Console (Web Application type).
# Add BOTH redirect URIs to the client's Authorized Redirect URIs:
#   https://allen.i.verse.rmasters.group/oauth/calendar/callback   (legacy, calendar-only)
#   https://allen.i.verse.rmasters.group/oauth/google/callback     (new, unified)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# The default account when no `account` param is given (calendar, gmail, drive tools).
DEFAULT_GOOGLE_ACCOUNT=rahmind.consulting@rmoorind.com
# Redirect URIs (override only if hosting under a different domain).
GOOGLE_OAUTH_REDIRECT=https://allen.i.verse.rmasters.group/oauth/calendar/callback
GOOGLE_OAUTH_UNIFIED_REDIRECT=https://allen.i.verse.rmasters.group/oauth/google/callback
# Legacy single-account calendar token (still honored; migrate by re-authing via /oauth/google/start).
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
#
# Authorize each of Rahm's 7 accounts at:
#   /oauth/google/start?account=EMAIL
# Accounts:
#   rmoorind@rmoorind.com
#   rahmind.consulting@rmoorind.com   ← default
#   rmoorindustries@gmail.com
#   amg@apex-meridian-group.com
#   rahm@rmasters.group
#   kingrahjah@gmail.com
#   rmooreking@gmail.com

# --- Google Drive (script drafts → Google Docs + YouTube media archive) ---
# Separate Drive credentials used by the docs.py / youtube_ingest backend writers.
# These are distinct from the unified Google OAuth above.
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=
# Drive folder where ALLEN writes script drafts for review.
GDRIVE_SCRIPTS_FOLDER_ID=
# Drive folder where YouTube ingests (audio/transcript/video) are saved for ALLIE's research + b-roll.
GDRIVE_YOUTUBE_FOLDER_ID=

# --- GitHub App — ALLEN's own bot identity (allen-piaar-control-bot) ---
# Registered under the RMoor-Industries-Ltd-Co org (org-admin action, done once via
# GitHub's UI — see rmg-piaar-system/docs/initiatives/01-allen-github-bridge-plan.md).
# Installed across every repo in the org; issues read/write everywhere, contents write
# restricted to rmg-piaar-system only (enforced in allen/tools_github.py).
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# PEM private key generated when the App was registered. Paste with literal \n for
# newlines if your secret store requires a single-line value (tools_github.py unescapes it).
GITHUB_APP_PRIVATE_KEY=

# --- Twilio / WhatsApp ---
# Twilio account credentials (console.twilio.com → API keys & Auth tokens).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox sender (whatsapp:+14155238886) or production registered number.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Rahm's personal WhatsApp number — the only authorized inbound sender.
TWILIO_WHATSAPP_TO=whatsapp:+1YOURNUMBER
# Time to send the daily morning brief (HH:MM, server local time).
# Set the TZ environment variable on the container to match your timezone.
DAILY_REPORT_TIME=07:00

# --- Feed watch (ALLIE → Thoth, axis-tekhen) ---
# ALLIE periodically scans configured tickers for "hot instrument" signals
# (yfinance news/volume bursts now; YouTube mention volume once the API key
# below is set) and pushes hits to Thoth's ingest endpoint. Off by default —
# every field below must be set for the scheduler to start this job.
FEED_WATCH_ENABLED=false
FEED_WATCH_TICKERS=
FEED_WATCH_INTERVAL_MINUTES=30
# axis-tekhen's Thoth ingest endpoint, e.g. https://axis-tekhen.rmasters.group/api/stocks/thoth/signals
THOTH_INGEST_URL=
# Shared secret — must match THOTH_INGEST_TOKEN set on the axis-tekhen backend.
THOTH_INGEST_TOKEN=
# YouTube Data API v3 key (console.cloud.google.com) — separate from yt-dlp
# ingest above; needed only for feed-watch's YouTube mention-volume scan.
YOUTUBE_DATA_API_KEY=

# --- Agent network — pull-ready reports (ALLEN's executive rollup) ---
# ALLIE pulls each domain's already-cached report instead of triggering live work.
# All optional; the rollup scheduler job only starts once at least one is set.
# axis-tekhen's Anpu review feed, e.g. https://axis-tekhen.rmasters.group/api/system/anpu/reviews
ANPU_REVIEWS_URL=
ANPU_REVIEWS_TOKEN=
# axis-tekhen's Thoth candidate board, e.g. https://axis-tekhen.rmasters.group/api/stocks/thoth/candidates
THOTH_STATUS_URL=
THOTH_STATUS_TOKEN=
# Cappo_Meridian's live delegate_to_cappo task endpoint + its own agent key.
CAPPO_AGENT_URL=https://cappo.apex-meridian-group.com/api/agent
CAPPO_AGENT_KEY=
# Cappo_Meridian's cached executive report endpoint (distinct from CAPPO_AGENT_URL above),
# e.g. https://cappo.apex-meridian-group.com/api/agent/report
CAPPO_REPORT_URL=
# connection-circle's Constance agent — live delegation + cached report endpoints.
# Aggregate-metrics-only by design (see connection-circle/CLAUDE.md's privacy rule).
CONSTANCE_AGENT_URL=https://api.connectioncircle.app/api/agent
CONSTANCE_AGENT_KEY=
CONSTANCE_REPORT_URL=
# hvnhavenry-com's Vale agent — live delegation + cached report endpoints.
# Aggregate showroom-activity-only by design — never a specific visitor's conversation.
VALE_AGENT_URL=https://hvnhavenry.com/api/agent
VALE_AGENT_KEY=
VALE_REPORT_URL=

PORT=8090
