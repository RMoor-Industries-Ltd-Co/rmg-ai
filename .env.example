# Shared key required on /draft, /speak, /listen (blank = open).
ALLEN_API_KEY=

# ALLEN configuration. Copy to .env; never commit .env.

# --- LLM (the "company LLM" — TBD long-term) ---
ANTHROPIC_API_KEY=
# Override to the current preferred model id.
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Speech ---
# Reuse the RMG Creator OS ElevenLabs key (speech-out / "Express").
ELEVENLABS_API_KEY=
# ElevenLabs voice for ALLEN's own spoken responses (default: COM Coach Rahm).
ALLEN_VOICE_ID=Z3Gpg2pTWuj7g4RFQM9J
# Optional: OpenAI key for Whisper STT ("Listen"). Leave blank to disable /listen.
OPENAI_API_KEY=

# --- Google Drive (write script drafts as Google Docs) ---
# Reuse the Creator OS rclone Drive OAuth client + refresh token.
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=
# Drive folder where ALLEN writes script drafts for review.
GDRIVE_SCRIPTS_FOLDER_ID=
# Drive folder where YouTube ingests (audio/transcript/video) are saved for ALLIE's research + b-roll.
GDRIVE_YOUTUBE_FOLDER_ID=

# --- Twilio / WhatsApp ---
# Twilio account credentials (console.twilio.com → API keys & Auth tokens).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox sender (whatsapp:+14155238886) or production registered number.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Rahm's personal WhatsApp number — the only authorized inbound sender.
TWILIO_WHATSAPP_TO=whatsapp:+1YOURNUMBER
# Time to send the daily morning brief (HH:MM, server local time).
# Set the TZ environment variable on the container to match your timezone.
DAILY_REPORT_TIME=07:00

PORT=8090
